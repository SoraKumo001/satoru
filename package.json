{
  "name": "satoru-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm wasm:build && pnpm --filter satoru-render build",
    "build:js": "pnpm -r --if-present build",
    "bench:render": "tsx ./scripts/bench-render.ts",
    "dev:playground": "pnpm --filter playground dev",
    "dev:cloudflare": "pnpm --filter cloudflare-test dev",
    "test:visual": "pnpm --filter visual-test test",
    "test:cpp": "pnpm --dir tests run test",
    "test:cpp:configure": "pnpm --dir tests run configure",
    "test:cpp:build": "pnpm --dir tests run build",
    "test:cpp:run": "pnpm --dir tests run run",
    "wasm:configure": "tsx ./scripts/build-wasm.ts configure",
    "wasm:build": "tsx ./scripts/build-wasm.ts build",
    "wasm:docker:build": "tsx ./scripts/wasm-docker-build.ts",
    "release:check": "tsx ./scripts/release-check.ts",
    "docs:compatibility": "tsx ./scripts/generate-compatibility.ts",
    "example:high-throughput": "tsx ./scripts/high-throughput-example.ts",
    "format": "tsx ./scripts/format.ts",
    "docs:dev": "pnpm --filter satoru-docs start",
    "docs:build": "pnpm --filter satoru-docs build"
  },
  "devDependencies": {
    "@types/node": "25.7.0",
    "clang-format": "1.8.0",
    "next-exec": "1.0.1",
    "satoru-render": "workspace:*",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "repository": "https://github.com/SoraKumo001/satoru",
  "author": "SoraKumo <info@croud.jp>",
  "license": "MIT",
  "dependencies": {
    "jsdom": "29.1.1"
  }
}
